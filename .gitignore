*.duckdb.wal
*.lance/

# Generated pipeline artifacts (kept out of git; regenerate with the CLI)
data/processed/*
!data/processed/.gitkeep
data/exports/*
!data/exports/.gitkeep

# Vector indexes
*.sqlite-vec

# OS / editors
.DS_Store
Thumbs.db
